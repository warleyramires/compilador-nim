KW_PROC proc
ID media
LEFT_PARENTHESIS (
ID a
COLON :
TYPE_FLOAT float
COMMA ,
ID b
COLON :
TYPE_FLOAT float
RIGHT_PARENTHESIS )
COLON :
TYPE_FLOAT float
OP_ASSIGN =
NEWLINE \n
INDENT  
KW_VAR var
ID m
COLON :
TYPE_FLOAT float
NEWLINE \n
ID m
OP_ASSIGN =
LEFT_PARENTHESIS (
ID a
OP_PLUS +
ID b
RIGHT_PARENTHESIS )
OP_DIVISION /
NUM_FLOAT 2.0
NEWLINE \n
KW_RETURN return
ID m
NEWLINE \n
DEDENT  
$ $
